generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ─────────────────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Enums ──────────────────────────────────────────────────
enum UserRole {
  PARTICIPANT
  ORGANIZER
  JUDGE
  MENTOR
}

enum OrganizerDesignation {
  LEAD_ORGANIZER
  TECHNICAL_COORDINATOR
  EVENT_MANAGER
  VOLUNTEER_LEAD
  SPONSORSHIP_LEAD
}

enum DomainExpertise {
  AI_ML
  WEB3
  FULL_STACK
  MOBILE
  CYBERSECURITY
  DATA_SCIENCE
  DEVOPS
  GAME_DEV
  IOT
  OTHER
}

enum HackathonStatus {
  DRAFT
  REGISTRATION_OPEN
  ACTIVE
  JUDGING
  COMPLETED
  ARCHIVED
}

// ─── User Model ──────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole  @default(PARTICIPANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // ── Participant-specific fields ──
  githubUsername       String?   @unique
  githubId             String?   @unique
  preferredEmail       String?
  primaryTechStack     String[]
  consentCommitTracking Boolean  @default(false)
  consentLocationAccess Boolean  @default(false)

  // ── Organizer-specific fields ──
  organizationName  String?
  contactPhone      String?
  designation       OrganizerDesignation?
  organizationLogo  String?

  // ── Judge/Mentor-specific fields ──
  domainExpertise    DomainExpertise?
  linkedinUrl        String?
  portfolioUrl       String?
  availabilityStart  String?
  availabilityEnd    String?
  conflictOfInterest Boolean @default(false)

  // ── Relations ──
  accounts          Account[]
  sessions          Session[]
  teamMemberships   TeamMember[]
  organizedHackathons Hackathon[]   @relation("OrganizerHackathons")
  judgingHackathons  HackathonJudge[]
  mentoringHackathons HackathonMentor[]
}

// ─── Team Model ──────────────────────────────────────────────────
model Team {
  id              String   @id @default(cuid())
  name            String
  repoUrl         String
  hackathonId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hackathon       Hackathon   @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  members         TeamMember[]

  @@unique([name, hackathonId])
}

model TeamMember {
  id             String   @id @default(cuid())
  userId         String
  teamId         String
  githubUsername  String
  isLeader       Boolean  @default(false)
  joinedAt       DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

// ─── Hackathon Model ─────────────────────────────────────────────
model Hackathon {
  id              String          @id @default(cuid())
  name            String
  inviteCode      String          @unique @default(cuid())
  accessToken     String          @unique @default(cuid())
  organizerId     String
  status          HackathonStatus @default(DRAFT)
  startTime       DateTime
  endTime         DateTime
  venue           String?
  geofenceLatitude  Float?
  geofenceLongitude Float?
  geofenceRadius    Float?        @default(500)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  organizer       User            @relation("OrganizerHackathons", fields: [organizerId], references: [id])
  teams           Team[]
  judges          HackathonJudge[]
  mentors         HackathonMentor[]
}

model HackathonJudge {
  id           String   @id @default(cuid())
  userId       String
  hackathonId  String
  assignedAt   DateTime @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon    Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
}

model HackathonMentor {
  id           String   @id @default(cuid())
  userId       String
  hackathonId  String
  assignedAt   DateTime @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  hackathon    Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
}
