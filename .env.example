# ============================================================================
# CommitLens Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values

# ---------- MongoDB ----------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/commitlens?retryWrites=true&w=majority

# ---------- NextAuth ----------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-min-32-chars-change-me

# ---------- GitHub OAuth (for Participant auth) ----------
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ---------- Admin Credentials (seeded on first run) ----------
ADMIN_EMAIL=admin@commitlens.dev
ADMIN_PASSWORD=ChangeMe!Str0ng
